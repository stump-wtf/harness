{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/terminal/**",
              "ui_kits/charm-cli/**",
              "ui_kits/glow/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:JetBrains Mono|Space Mono|Silkscreen))/i]",
        "message": "Font not provided by the design system. Available: JetBrains Mono, Space Mono, Silkscreen."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, variant, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:primary|accent|info|success|warning|danger|muted)$/]",
        "message": "<Badge> tone must be one of 'primary' | 'accent' | 'info' | 'success' | 'warning' | 'danger' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|outline)$/]",
        "message": "<Badge> variant must be one of 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|focused|brackets|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, focused, brackets, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|success|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'success' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|label|cursor|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, label, cursor, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|icon|actions|tone|width|children|style|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: title, icon, actions, tone, width, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:primary|accent|danger|info|success)$/]",
        "message": "<Dialog> tone must be one of 'primary' | 'accent' | 'danger' | 'info' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kbd'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<Kbd> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kbd'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|accent|info)$/]",
        "message": "<Kbd> tone must be one of 'default' | 'accent' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KeyHintItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:keys|label|key|ref|className|style|children)$/]",
        "message": "<KeyHintItem> doesn't accept that prop. Declared props: keys, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|desc|badge|key|ref|className|style|children)$/]",
        "message": "<ListItem> doesn't accept that prop. Declared props: title, desc, badge."
      },
      {
        "selector": "JSXOpeningElement[name.name='Progress'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|gradient|showPercent|blocks|width|style|key|ref|className|style|children)$/]",
        "message": "<Progress> doesn't accept that prop. Declared props: value, gradient, showPercent, blocks, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Spinner'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|tone|label|speed|style|key|ref|className|style|children)$/]",
        "message": "<Spinner> doesn't accept that prop. Declared props: kind, tone, label, speed, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Spinner'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:braille|dots|line|moon|points)$/]",
        "message": "<Spinner> kind must be one of 'braille' | 'dots' | 'line' | 'moon' | 'points'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Spinner'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|primary|info|success|warning)$/]",
        "message": "<Spinner> tone must be one of 'accent' | 'primary' | 'info' | 'success' | 'warning'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBarSegment'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|tone|grow|icon|key|ref|className|style|children)$/]",
        "message": "<StatusBarSegment> doesn't accept that prop. Declared props: label, tone, grow, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBarSegment'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:primary|accent|info|success|warning|danger|muted|plain)$/]",
        "message": "<StatusBarSegment> tone must be one of 'primary' | 'accent' | 'info' | 'success' | 'warning' | 'danger' | 'muted' | 'plain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|width|align|key|ref|className|style|children)$/]",
        "message": "<TableColumn> doesn't accept that prop. Declared props: key, label, width, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<TableColumn> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|active|style|key|ref|className|style|children)$/]",
        "message": "<Tabs> doesn't accept that prop. Declared props: tabs, active, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TerminalWindow'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|dots|glow|padding|statusBar|width|style|children|key|ref|className|style|children)$/]",
        "message": "<TerminalWindow> doesn't accept that prop. Declared props: title, dots, glow, padding, statusBar, width, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='TerminalWindow'] > JSXAttribute[name.name='glow'] > Literal[value!=/^(?:purple|pink|cyan|none)$/]",
        "message": "<TerminalWindow> glow must be one of 'purple' | 'pink' | 'cyan' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|placeholder|prompt|focused|bordered|label|width|style|key|ref|className|style|children)$/]",
        "message": "<TextInput> doesn't accept that prop. Declared props: value, placeholder, prompt, focused, bordered, label, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:on|onLabel|offLabel|tone|style|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: on, onLabel, offLabel, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|primary|accent|info)$/]",
        "message": "<Toggle> tone must be one of 'success' | 'primary' | 'accent' | 'info'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
